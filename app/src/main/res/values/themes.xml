<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Ghosthand" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/gh_brand_primary</item>
        <item name="colorPrimaryVariant">@color/gh_brand_primary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/gh_brand_primary</item>
        <item name="colorSecondaryVariant">@color/gh_brand_primary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/gh_surface_card</item>
        <item name="colorOnSurface">@color/gh_text_primary</item>
        <item name="android:windowBackground">@color/gh_window_background</item>
        <item name="android:statusBarColor">@color/gh_window_background</item>
        <item name="android:navigationBarColor">@color/gh_window_background</item>
    </style>

    <style name="Widget_Ghosthand_InfoButton">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">1dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:src">@drawable/ic_info_affordance</item>
        <item name="android:tint">@color/gh_brand_primary</item>
    </style>
</resources>
